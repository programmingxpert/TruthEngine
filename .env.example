# Copy this file to .env for local overrides.
# Docker Compose also provides these defaults directly.

TRUTHENGINE_ENVIRONMENT=local
TRUTHENGINE_SERVICE_NAME=truthengine-api
TRUTHENGINE_APP_VERSION=0.1.0
TRUTHENGINE_LOG_LEVEL=INFO
TRUTHENGINE_LOG_JSON=true
TRUTHENGINE_REQUEST_ID_HEADER=X-Request-ID
TRUTHENGINE_DATABASE_URL=postgresql+psycopg://truthengine:truthengine@localhost:5432/truthengine
TRUTHENGINE_SEARXNG_URL=http://localhost:8888
TRUTHENGINE_SEARXNG_MAX_RESULTS=6
TRUTHENGINE_DEEPSEEK_API_KEY=
TRUTHENGINE_DEEPSEEK_MODEL=deepseek-chat
TRUTHENGINE_DEEPSEEK_BASE_URL=https://api.deepseek.com
TRUTHENGINE_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
